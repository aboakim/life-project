# Deploy (Vercel + Neon): see docs/DEPLOY_CHECKLIST.md
#
# Optional: enables live OpenAI analysis (gpt-4o-mini by default) and, when
# /api/speech/available reports availability, server-side voice transcription
# (Whisper) on the home analyzer form.
OPENAI_API_KEY=

# Optional override
# OPENAI_MODEL=gpt-4o-mini
# Optional: Whisper transcriptions (default whisper-1)
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# Preview/staging banner on the home page (shows a small “local / preview” notice).
# NEXT_PUBLIC_DEMO_MODE=1

# Production site URL (SEO / Open Graph). Example: https://your-domain.com
# Leave unset for local dev. Do not set to empty — invalid/empty URL breaks metadata (HTTP 500).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Google Analytics 4 (optional) ---
# Create a GA4 property at https://analytics.google.com → copy the Measurement ID.
# Only loads in production; consent-mode defaults are "denied" until a CMP flips them.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Public contact email (optional) ---
# Displayed on /contact and used as the mailto target in the contact form.
# Falls back to a placeholder when unset.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com

# --- Domain & hosting (no secret: configure at your DNS / hosting provider) ---
# Point www.example.com to your host:
#   • Vercel/Netlify: add the domain in their dashboard; they give you DNS records (often CNAME/A).
#   • VPS: set DNS A record @ and www to your server public IP; terminate TLS with nginx/Caddy + Let's Encrypt.
# Your app does not read "the IP" from .env — users reach you by domain; the host routes to this Node app.

# --- Google AdSense (optional; revenue paid out in the AdSense dashboard, not via this repo) ---
# 1) Apply at https://www.google.com/adsense/ — site must comply with policies.
# 2) After approval, create ad units; put your publisher ID and slot IDs here:
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=xxxxxxxxxx
# Ads appear only when both are set. Stripe subscription revenue is separate (see STRIPE_* above).

# PostgreSQL — required for Prisma (local + Vercel). Use Neon, Supabase, or Docker.
# Example (Neon): postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/life_dev"

# Stripe — server-only secrets (never NEXT_PUBLIC_*)
# Dashboard: Product with recurring Price → STRIPE_PRICE_ID_PREMIUM=price_...
# Webhook URL: https://YOUR_DOMAIN/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_PREMIUM=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... (only if you add Stripe.js / Elements later)
# See docs/STRIPE_LEGAL_AND_SECURITY.md

# Admin dashboard at /admin (min 16 characters). Diagnostics: /admin/diagnostics
# ADMIN_SECRET=

# Optional: direct link to this project’s runtime logs (shown only after admin login)
# VERCEL_DASHBOARD_LOGS_URL=https://vercel.com/<team>/<project>/logs
# ADMIN_LOGS_URL=

# Resend — email when someone contacts an expert (optional)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Life Decision Engine <onboarding@resend.dev>

# ---------------------------------------------------------------------
# Monetization — affiliate links, donations, direct sponsors (optional)
# ---------------------------------------------------------------------
# All of these are safe to expose (NEXT_PUBLIC_*) because they are
# client-visible referral links, not secrets. Each block renders a UI
# element only when its URL is set — leave blank to hide.
#
# --- Buy Me a Coffee / Ko-fi: renders "Support this project" in footer ---
# Sign up: https://www.buymeacoffee.com  (or https://ko-fi.com)
# If unset, the same button links to /contact so the CTA is never hidden.
# NEXT_PUBLIC_BUYMEACOFFEE_URL=https://www.buymeacoffee.com/yourname
# NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/yourname
# NEXT_PUBLIC_SUPPORT_LABEL=Support this project  # custom button text
#
# --- Affiliate links shown inline in relevant blog articles ---
# Wise (~$50/qualified signup):   https://wise.com/campaigns/partner-signup
# Revolut:                         https://www.revolut.com/business/affiliate
# Booking.com (4% commission):    https://www.booking.com/affiliate-program
# Airbnb ($18-28/host signup):    https://www.airbnb.com/associates
# NEXT_PUBLIC_WISE_AFFILIATE_URL=
# NEXT_PUBLIC_REVOLUT_AFFILIATE_URL=
# NEXT_PUBLIC_BOOKING_AFFILIATE_URL=
# NEXT_PUBLIC_AIRBNB_AFFILIATE_URL=
#
# --- Amazon Associates (blog CTA; standard disclosure in UI) ---
# If unset, the app falls back to DEFAULT_AMAZON_ASSOCIATES_TAG in lib/monetization/config.ts
# so the CTA still appears without Vercel env (SSG + build-cache safe).
# NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=lifedecisions-20
# Or full URL (overrides tag-built link):
# NEXT_PUBLIC_AMAZON_AFFILIATE_URL=https://www.amazon.com/dp/XXXXXXXXXX?tag=lifedecisions-20
# To hide the Amazon block: NEXT_PUBLIC_AMAZON_ASSOCIATES_DISABLED=1
#
# --- Direct advertiser slot (self-sold sponsor, shown once on articles) ---
# Set all 4 required fields to enable. AdSense-compliant (rel="sponsored").
# NEXT_PUBLIC_SPONSOR_NAME=Acme Bank
# NEXT_PUBLIC_SPONSOR_TITLE=Plan your first mortgage the calm way
# NEXT_PUBLIC_SPONSOR_BLURB=A simple calculator and a human advisor, free to use.
# NEXT_PUBLIC_SPONSOR_URL=https://example.com/?utm_source=lifedecisions
# NEXT_PUBLIC_SPONSOR_CTA=Open the calculator  # optional
# NEXT_PUBLIC_SPONSOR_LOGO_URL=               # optional
