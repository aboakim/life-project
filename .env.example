# Deploy (Vercel + Neon): see docs/DEPLOY_CHECKLIST.md
#
# Optional: enables live OpenAI analysis (gpt-4o-mini by default)
OPENAI_API_KEY=

# Optional override
# OPENAI_MODEL=gpt-4o-mini

# Production site URL (SEO / Open Graph). Example: https://your-domain.com
# Leave unset for local dev. Do not set to empty — invalid/empty URL breaks metadata (HTTP 500).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Domain & hosting (no secret: configure at your DNS / hosting provider) ---
# Point www.example.com to your host:
#   • Vercel/Netlify: add the domain in their dashboard; they give you DNS records (often CNAME/A).
#   • VPS: set DNS A record @ and www to your server public IP; terminate TLS with nginx/Caddy + Let's Encrypt.
# Your app does not read "the IP" from .env — users reach you by domain; the host routes to this Node app.

# --- Google AdSense (optional; revenue paid out in the AdSense dashboard, not via this repo) ---
# 1) Apply at https://www.google.com/adsense/ — site must comply with policies.
# 2) After approval, create ad units; put your publisher ID and slot IDs here:
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=xxxxxxxxxx
# Ads appear only when both are set. Stripe subscription revenue is separate (see STRIPE_* above).

# SQLite locally. For production use PostgreSQL (Neon, Supabase) and set DATABASE_URL accordingly.
DATABASE_URL="file:./dev.db"

# Stripe — server-only secrets (never NEXT_PUBLIC_*)
# Dashboard: Product with recurring Price → STRIPE_PRICE_ID_PREMIUM=price_...
# Webhook URL: https://YOUR_DOMAIN/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_PREMIUM=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... (only if you add Stripe.js / Elements later)
# See docs/STRIPE_LEGAL_AND_SECURITY.md

# Admin dashboard at /admin (min 16 characters)
# ADMIN_SECRET=

# Resend — email when someone contacts an expert (optional)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Life Decision Engine <onboarding@resend.dev>
