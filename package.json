{
  "name": "life-decision-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0",
    "dev:lan:3001": "next dev -H 0.0.0.0 -p 3001",
    "dev:3001": "next dev -p 3001",
    "fresh:3001": "node scripts/clean-next.cjs && next dev -p 3001",
    "clean": "node scripts/clean-next.cjs",
    "dev:fresh": "node scripts/clean-next.cjs && next dev",
    "fresh": "node scripts/clean-next.cjs && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "node scripts/ensure-database-url.mjs && prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/postinstall-prisma.mjs",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/analytics": "^2.0.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.11.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
